ocker/%E9%95%9C%E5%83%8F%E6%BA%90%E4%B8%8E%E4%BB%A3%E7%90%86/#_3","title":"\u5e94\u7528","text":"<pre><code>#\u91cd\u542fdaemon\u8fdb\u7a0b\nsudo systemctl daemon-reload\n#\u91cd\u542fdocker\u670d\u52a1\nsudo systemctl restart docker\n</code></pre>"},{"location":"Docker/%E9%95%9C%E5%83%8F%E6%BA%90%E4%B8%8E%E4%BB%A3%E7%90%86/#_4","title":"\u67e5\u770b\u914d\u7f6e\u7ed3\u679c","text":"<pre><code>docker info\n</code></pre>"},{"location":"Docker/%E9%95%9C%E5%83%8F%E6%BA%90%E4%B8%8E%E4%BB%A3%E7%90%86/#ref","title":"Ref","text":"<p>https://blog.csdn.net/Lichen0196/article/details/137355517</p>"},{"location":"DotNet/NugetLicense/","title":"NuGet License","text":"<p>https://learn.microsoft.com/zh-cn/nuget/reference/msbuild-targets#packing-a-license-expression-or-a-license-file https://www.cnblogs.com/weihanli/p/10201751.html https://spdx.org/licenses/</p>"},{"location":"FrontEnd/React/DevMode/","title":"Dev Mode","text":"<pre><code>const isDev = process.env.NODE_ENV === 'development';\n</code></pre>"},{"location":"FrontEnd/React/DevMode/#ref","title":"Ref","text":"<p>https://blog.csdn.net/BradenHan/article/details/132324278</p>"},{"location":"FrontEnd/React/UMI/DarkMode/","title":"AntD5 Dark Mode","text":"<p>\u53c2\u8003UMI\u6587\u6863\u7684<code>\u52a8\u6001\u5207\u6362\u5168\u5c40\u914d\u7f6e</code></p>"},{"location":"FrontEnd/React/UMI/DarkMode/#ref","title":"Ref","text":"<p>https://umijs.org/docs/max/antd https://github.com/luffyZh/antd-v5-dark-change-demo/blob/main/src/index.js https://juejin.cn/post/7242284648021164091</p>"},{"location":"FrontEnd/React/UMI/Env/","title":"ENV","text":"<pre><code>  define: {\n    'process.env.GROUP_CENTER_URL': process.env.GROUP_CENTER_URL,\n  },\n</code></pre>"},{"location":"FrontEnd/React/UMI/Env/#ref","title":"Ref","text":"<p>https://blog.csdn.net/hzxOnlineOk/article/details/126182179</p>"},{"location":"FrontEnd/React/UMI/OpenAPI/","title":"Ant Design Pro OpenAPI","text":""},{"location":"FrontEnd/React/UMI/OpenAPI/#ref","title":"Ref","text":"<p>https://pro.ant.design/zh-CN/docs/openapi/</p>"},{"location":"FrontEnd/React/UMI/ProxyAndNginX/","title":"Proxy And NginX","text":""},{"location":"FrontEnd/React/UMI/ProxyAndNginX/#ref","title":"Ref","text":"<p>https://umijs.org/docs/guides/proxy</p>"},{"location":"FrontEnd/React/%E5%85%A5%E9%97%A8/%E7%88%B6%E7%BB%84%E4%BB%B6%E8%B0%83%E7%94%A8%E5%AD%90%E7%BB%84%E4%BB%B6%E7%9A%84%E5%87%BD%E6%95%B0/","title":"\u7236\u7ec4\u4ef6\u8c03\u7528\u5b50\u7ec4\u4ef6\u7684\u51fd\u6570","text":""},{"location":"FrontEnd/React/%E5%85%A5%E9%97%A8/%E7%88%B6%E7%BB%84%E4%BB%B6%E8%B0%83%E7%94%A8%E5%AD%90%E7%BB%84%E4%BB%B6%E7%9A%84%E5%87%BD%E6%95%B0/#js","title":"JS","text":"<pre><code>const { Component } = React;\n\nclass Parent extends Component {\n  constructor(props) {\n    super(props);\n    this.child = React.createRef();\n  }\n\n  onClick = () =&gt; {\n    this.child.current.getAlert();\n  };\n\n  render() {\n    return (\n      &lt;div&gt;\n        &lt;Child ref={this.child} /&gt;\n        &lt;button onClick={this.onClick}&gt;Click&lt;/button&gt;\n      &lt;/div&gt;\n    );\n  }\n}\n\nclass Child extends Component {\n  getAlert() {\n    alert('getAlert from Child');\n  }\n\n  render() {\n    return &lt;h1&gt;Hello&lt;/h1&gt;;\n  }\n}\n\nReactDOM.render(&lt;Parent /&gt;, document.getElementById('root'));\n</code></pre>"},{"location":"FrontEnd/React/%E5%85%A5%E9%97%A8/%E7%88%B6%E7%BB%84%E4%BB%B6%E8%B0%83%E7%94%A8%E5%AD%90%E7%BB%84%E4%BB%B6%E7%9A%84%E5%87%BD%E6%95%B0/#ts","title":"TS","text":"<pre><code>import React, {forwardRef, useRef, useImperativeHandle} from \"react\";\n\ninterface CanShowAlert {\n  showAlert(): void;\n}\n\nexport default function App() {\n  const childRef = useRef&lt;CanShowAlert&gt;(null);\n  return (\n    &lt;div className=\"container\"&gt;\n\n      &lt;Child ref={childRef} /&gt;\n      &lt;button\n        onClick={() =&gt; { childRef.current?.showAlert() }}\n      &gt;\n        Call Function\n            &lt;/button&gt;\n\n    &lt;/div&gt;\n  )\n}\n\n// \u6ce8\u610f\uff0c\u8fd9\u91ccChild\u7684\u7c7b\u578b\u4e0d\u884c\u5c31\u76f4\u63a5\u7701\u7565\uff0c\u5220\u9664\u6389\n// const Child: React.FC&lt;Props&gt; = forwardRef&lt;CanShowAlert, {}&gt;((props, ref) =&gt; {\n\nconst Child = forwardRef&lt;CanShowAlert, {}&gt;((props, ref) =&gt; {\n    useImperativeHandle(\n        ref,\n        () =&gt; ({\n             showAlert() {\n                alert(\"Child Function Called\")\n                console.log('hello world')\n            }\n        }),\n    )\n    return (\n        &lt;div&gt;Child Component&lt;/div&gt;\n    )\n})\n</code></pre>"},{"location":"FrontEnd/React/%E5%85%A5%E9%97%A8/%E7%88%B6%E7%BB%84%E4%BB%B6%E8%B0%83%E7%94%A8%E5%AD%90%E7%BB%84%E4%BB%B6%E7%9A%84%E5%87%BD%E6%95%B0/#ref","title":"Ref","text":"<p>https://stackoverflow.com/questions/37949981/call-child-method-from-parent https://stackoverflow.com/questions/66363320/call-child-function-from-parent-in-reactjs-using-useref</p>"},{"location":"Git/%E5%A4%A7%E5%B0%8F%E5%86%99/","title":"Git \u5927\u5c0f\u5199","text":"<p>\u8fd9\u4e2a\u95ee\u9898\u4e00\u822c\u51fa\u73b0\u5728<code>Windows</code>\u64cd\u4f5c\u7cfb\u7edf\u4e2d\u3002</p>"},{"location":"Git/%E5%A4%A7%E5%B0%8F%E5%86%99/#_1","title":"\u7981\u6b62\u5ffd\u7565\u5927\u5c0f\u5199","text":"<pre><code>git config core.ignorecase false\n</code></pre>"},{"location":"Java/Spring/%E7%83%AD%E9%83%A8%E7%BD%B2/","title":"Spring Boot \u70ed\u90e8\u7f72","text":""},{"location":"Java/Spring/%E7%83%AD%E9%83%A8%E7%BD%B2/#gradle","title":"Gradle","text":"<pre><code>// https://mvnrepository.com/artifact/org.springframework.boot/spring-boot-devtools\nimplementation(\"org.springframework.boot:spring-boot-devtools:3.3.0\")\n\n// https://mvnrepository.com/artifact/org.springframework.boot/spring-boot-gradle-plugin\nimplementation(\"org.springframework.boot:spring-boot-gradle-plugin:3.3.0\")\n</code></pre>"},{"location":"Java/Spring/%E7%83%AD%E9%83%A8%E7%BD%B2/#ref","title":"Ref","text":"<p>https://blog.csdn.net/sinat_40770656/article/details/102469092 https://blog.csdn.net/Martin_chen2/article/details/116198924 https://blog.csdn.net/qq_52978553/article/details/122376118</p>"},{"location":"Python/PythonVSCode%E7%BC%A9%E8%BF%9B/","title":"Python VSCode\u7f29\u8fdb\u95ee\u9898","text":""},{"location":"Python/PythonVSCode%E7%BC%A9%E8%BF%9B/#ref","title":"Ref","text":"<p>https://blog.csdn.net/Dr_Myst/article/details/104199272</p>"},{"location":"Python/%E6%B8%85%E7%90%86%E7%BC%93%E5%AD%98/","title":"Python\u5305\u7f13\u5b58\u6e05\u7406","text":""},{"location":"Python/%E6%B8%85%E7%90%86%E7%BC%93%E5%AD%98/#pip","title":"\u6e05\u7406pip\u7f13\u5b58","text":"<pre><code>pip cache purge\n</code></pre>"},{"location":"Python/%E6%B8%85%E7%90%86%E7%BC%93%E5%AD%98/#conda","title":"\u6e05\u7406conda\u7f13\u5b58","text":"<pre><code>conda clean --all\n</code></pre>"}]}